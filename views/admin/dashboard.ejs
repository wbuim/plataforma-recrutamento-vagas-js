<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#007bff">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <title>W-Code | Super Admin</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f4f7f6; margin: 0; display: flex; }

        .sidebar { width: 260px; background: #2c3e50; color: white; height: 100vh; padding: 20px; position: fixed; top: 0; left: 0; box-sizing: border-box; overflow-y: auto; z-index: 100; transition: transform 0.3s ease; }
        .sidebar h2 { margin-top: 0; }

        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); box-sizing: border-box; }

        .grid-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); text-align: center; border-top: 5px solid #007bff; }
        .box { background: white; padding: 25px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 30px; }

        .table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; min-width: 480px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; font-size: 0.9rem; }
        th { background: #f8f9fa; color: #555; }

        .btn-action { text-decoration: none; color: #007bff; font-weight: bold; }
        .btn-csv { display: inline-block; background: #27ae60; color: white; padding: 10px 15px; border-radius: 5px; text-decoration: none; font-size: 0.8rem; margin-bottom: 15px; }

        .alerta-box { background: #fff8e1; border-left: 5px solid #f59e0b; border-radius: 10px; padding: 20px 25px; margin-bottom: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .alerta-box h3 { margin-top: 0; color: #92400e; }
        .alerta-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #fde68a; flex-wrap: wrap; gap: 8px; }
        .alerta-item:last-child { border-bottom: none; padding-bottom: 0; }
        .alerta-info strong { color: #1a1a1a; }
        .alerta-info span { font-size: 0.85rem; color: #555; display: block; margin-top: 2px; }
        .alerta-data { font-size: 0.8rem; color: #92400e; background: #fde68a; padding: 4px 10px; border-radius: 20px; white-space: nowrap; font-weight: bold; }

        /* Hamburger (mobile only) */
        .topbar { display: none; background: #2c3e50; color: white; padding: 12px 16px; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 200; }
        .topbar span { font-weight: bold; font-size: 1.1rem; }
        .hamburger { background: none; border: none; color: white; font-size: 1.6rem; cursor: pointer; line-height: 1; }

        .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 99; }
        .overlay.ativo { display: block; }

        @media (max-width: 768px) {
            body { display: block; }
            .topbar { display: flex; }
            .sidebar { transform: translateX(-100%); }
            .sidebar.aberto { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 20px 14px; width: 100%; }
            .grid-stats { grid-template-columns: 1fr 1fr; gap: 12px; }
        }

        @media (max-width: 400px) {
            .grid-stats { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="topbar">
        <span>W-Code Admin</span>
        <button class="hamburger" onclick="toggleSidebar()">&#9776;</button>
    </div>
    <div class="overlay" id="overlay" onclick="fecharSidebar()"></div>
    <div class="sidebar" id="sidebar">
        <h2>W-Code Admin</h2>
        <p>Logado como: <strong><%= usuario.nome %></strong></p>
        <hr>
        <a href="/admin/exportar/candidatos_full" class="btn-csv" style="background:#2980b9; width: 85%;">📥 Exportar Candidatos</a><br>
        <a href="/admin/exportar/empresas_full" class="btn-csv" style="width: 85%;">📥 Exportar Empresas</a>
        <br><br>
        <a href="/logout" style="color: #e74c3c; text-decoration: none; font-weight: bold;">🚪 Sair do Sistema</a>
    </div>

    <div class="main-content">
        <h1>Painel de Controle Estratégico</h1>

        <% if (vagasPreenchidas.length > 0) { %>
        <div class="alerta-box">
            <h3>🔔 Vagas Preenchidas — Comunicar ao Setor (<%= vagasPreenchidas.length %>)</h3>
            <% vagasPreenchidas.forEach(v => { %>
            <div class="alerta-item">
                <div class="alerta-info">
                    <strong><%= v.titulo %></strong>
                    <span>Empresa: <%= v.empresa.nome %></span>
                </div>
                <span class="alerta-data">✅ <%= new Date(v.preenchidaEm).toLocaleString('pt-BR') %></span>
            </div>
            <% }) %>
        </div>
        <% } %>

        <div class="grid-stats">
            <div class="card"><h3>Total Candidatos</h3><p><%= stats.totalCandidatos %></p></div>
            <div class="card"><h3>Empresas Parceiras</h3><p><%= stats.totalEmpresas %></p></div>
            <div class="card"><h3>Vagas no Mural</h3><p><%= stats.totalVagas %></p></div>
        </div>

        <div class="box">
            <h3>📑 Gestão de Vagas Ativas</h3>
            <div class="table-wrapper">
            <table>
                <thead><tr><th>Vaga</th><th>Empresa</th><th>Data</th><th>Ação</th></tr></thead>
                <tbody>
                    <% todasVagas.forEach(v => { %>
                        <tr>
                            <td><strong><%= v.titulo %></strong></td>
                            <td><%= v.empresa.nome %></td>
                            <td><%= new Date(v.createdAt).toLocaleDateString() %></td>
                            <td><a href="/admin/vaga/<%= v.id %>" class="btn-action">👁️ Ver Candidatos</a></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            </div>
        </div>

        <div class="box">
            <h3>🏢 Listagem de Empresas</h3>
            <div class="table-wrapper">
            <table>
                <thead><tr><th>Nome</th><th>CNPJ</th><th>E-mail Corporativo</th></tr></thead>
                <tbody>
                    <% todasEmpresas.forEach(e => { %>
                        <tr>
                            <td><%= e.nome %></td>
                            <td><%= e.cnpj || 'Não informado' %></td>
                            <td><%= e.email %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            </div>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('aberto');
            document.getElementById('overlay').classList.toggle('ativo');
        }
        function fecharSidebar() {
            document.getElementById('sidebar').classList.remove('aberto');
            document.getElementById('overlay').classList.remove('ativo');
        }
    </script>
</body>
</html>